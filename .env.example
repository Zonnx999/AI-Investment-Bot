# 이 파일을 복사해서 .env 라는 이름으로 만들고, 키들을 채워넣으세요.
# .env 는 .gitignore 에 포함되어 있어 GitHub에 절대 올라가지 않습니다.

# === LLM ===
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=

# === 시장 데이터 ===
# https://fred.stlouisfed.org/docs/api/api_key.html 에서 무료 발급
FRED_API_KEY=

# https://site.financialmodelingprep.com/ (유료 — 전 종목 스크리닝)
FMP_API_KEY=

# 한국거래소 정보데이터시스템 OpenAPI (http://data.krx.co.kr) — 한국 전수조사용
# ※ 키 발급 후 사용할 API 를 포털에서 개별 '신청/활성화' 해야 함 (Phase 9)
KRX_API_KEY=

# === 뉴스 (Phase 5) ===
# https://newsapi.org/ 무료 티어
NEWS_API_KEY=

# === 알림 채널 (Phase 7) ===
# 1) Telegram 앱에서 @BotFather 에게 /newbot → 받은 토큰 붙여넣기
TELEGRAM_BOT_TOKEN=
# 2) 봇에게 아무 메시지나 보낸 뒤 `python scripts/telegram_setup.py` 실행 → 출력된 숫자
TELEGRAM_CHAT_ID=
