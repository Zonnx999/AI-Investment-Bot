# 이 파일을 복사해서 .env 라는 이름으로 만들고, 키들을 채워넣으세요.
# .env 는 .gitignore 에 포함되어 있어 GitHub에 절대 올라가지 않습니다.

# === LLM ===
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=

# === 시장 데이터 ===
# https://fred.stlouisfed.org/docs/api/api_key.html 에서 무료 발급
FRED_API_KEY=

# https://site.financialmodelingprep.com/ (선택, Phase 1 후반에 필요)
FMP_API_KEY=

# 관세청 UNIPASS OpenAPI (선택, 한국 무역통계 일별/HS코드별)
# https://unipass.customs.go.kr/openapi/ 에서 가입 후 서비스별 인증키 발급
UNIPASS_API_KEY=

# === 뉴스 (Phase 5) ===
# https://newsapi.org/ 무료 티어
NEWS_API_KEY=

# === 챗봇 채널 (Phase 6, 선택) ===
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
