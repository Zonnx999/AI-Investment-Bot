# 이 파일을 복사해서 .env 라는 이름으로 만들고, 키들을 채워넣으세요.
# .env 는 .gitignore 에 포함되어 있어 GitHub에 절대 올라가지 않습니다.

# === LLM ===
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=

# === 시장 데이터 ===
# https://fred.stlouisfed.org/docs/api/api_key.html 에서 무료 발급
FRED_API_KEY=

# https://site.financialmodelingprep.com/ (유료 — 전 종목 스크리닝)
FMP_API_KEY=

# 한국거래소 정보데이터시스템 OpenAPI (http://data.krx.co.kr) — 한국 전수조사용
# ※ 키 발급 후 사용할 API 를 포털에서 개별 '신청/활성화' 해야 함 (Phase 9a)
KRX_API_KEY=

# DART 전자공시 OpenAPI (https://opendart.fss.or.kr) — 한국 재무제표/펀더멘털 (Phase 9b)
# 무료 가입 후 인증키 발급
DART_API_KEY=

# === 뉴스 (Phase 5) ===
# https://newsapi.org/ 무료 티어
NEWS_API_KEY=

# === 알림 채널 (Phase 7) ===
# 1) Telegram 앱에서 @BotFather 에게 /newbot → 받은 토큰 붙여넣기
TELEGRAM_BOT_TOKEN=
# 2) 봇에게 아무 메시지나 보낸 뒤 `python scripts/telegram_setup.py` 실행 → 출력된 숫자
#    이 chat_id 가 '소유자'(Phase 11a 승인자) 겸 항상 수신자가 됩니다.
TELEGRAM_CHAT_ID=

# === 멀티유저 브로드캐스트 (Phase 11a) — 소유자 승인제, 추가 설정 불필요 ===
# 친구가 봇에게 /start → 소유자(TELEGRAM_CHAT_ID)에게 승인 요청 알림 → /approve <chat_id> 로 승인.
# 비밀코드 없음. 승인은 다음 cron 폴링 때 반영됨.

# === 호스팅 DB (Phase 10) — Turso(libSQL) ===
# turso db show <db> --url  /  turso db tokens create <db>  (scripts/turso_setup.py 참고)
# 둘 다 비우면 로컬 sqlite3(data/quant_bot.db) 사용
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
